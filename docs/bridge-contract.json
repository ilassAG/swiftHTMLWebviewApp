  "legacyCompatibility": {
    "description": "Known legacy response omissions that are intentionally preserved for existing web apps until the corresponding action is versioned or normalized.",
    "actions": {
      "scanDocument": {
        "platforms": ["ios"],
        "omitsRecommendedFields": ["platform", "requestId", "success"],
        "reason": "Existing iOS document-scan integrations consume legacy pages/images/pdfData fields without the newer envelope fields.",
        "tests": [
          "ios/swiftHTMLWebviewAppTests/CaptureResponseBuilderTests.swift"
        ]
      },
      "takePhoto": {
        "platforms": ["ios"],
        "omitsRecommendedFields": ["platform", "requestId", "success"],
        "reason": "Existing iOS photo integrations consume legacy imageData/background fields without the newer envelope fields.",
        "tests": [
          "ios/swiftHTMLWebviewAppTests/CaptureResponseBuilderTests.swift"
        ]
      },
      "scanBarcode": {
        "platforms": ["ios"],
        "omitsRecommendedFields": ["platform", "requestId", "success"],
        "reason": "Existing iOS one-shot scanner integrations consume legacy code/format fields without the newer envelope fields.",
        "tests": [
          "ios/swiftHTMLWebviewAppTests/BarcodeResponseBuilderTests.swift"
        ]
      }
    }
  },
